# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Server ---
PORT=3000

# --- Auth (this is a single-operator app: one login for you) ---
# Generate a strong random string for JWT_SECRET, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=you@example.com
# Set this on first boot only — run `npm run seed-admin` locally (or once via a
# one-off deploy command) to hash it into the database, then remove it from .env.
ADMIN_PASSWORD=change-me

# --- OpenAI (used server-side now, for scheduled runs with nobody watching) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Scheduled pipeline run (cron syntax, server time) ---
# Example: "0 8 * * *" = every day at 08:00. Leave empty to disable scheduling.
PIPELINE_CRON=0 8 * * *
PIPELINE_BUSINESS_CONTEXT=Décris ici ton business pour les lancements automatiques.

# --- Email (used for: scheduled run summaries + real Sales Rep outreach) ---
# Option A (recommended): Resend's HTTP API — works over plain HTTPS, so it
# isn't affected by hosts that block outbound SMTP ports (a common issue on
# Railway/Render/etc). Get a free API key at resend.com, no credit card.
RESEND_API_KEY=re_...
EMAIL_FROM="Business Agents OS <onboarding@resend.dev>"
NOTIFY_EMAIL=you@example.com

# Option B: plain SMTP (used only if RESEND_API_KEY is not set). Works fine
# locally / on hosts that allow outbound SMTP; may time out on some PaaS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-app-password

# --- Content publishing webhook (optional) ---
# Point this at a Zapier/Make/n8n webhook (or your own endpoint) to actually
# publish content when you mark a Content item as "publié". Leave empty to
# just log the attempt without calling anything.
PUBLISH_WEBHOOK_URL=
